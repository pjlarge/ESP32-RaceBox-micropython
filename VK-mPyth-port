def interpret_serial_input():
    """
    Poll stdin for a single character and dispatch to stub functions.
    Non-blocking: returns immediately if nothing is available.
    """
    try:
        import select
        r, _, _ = select.select([sys.stdin], [], [], 0)
        if not r:
            return
        ch = sys.stdin.read(1)
    except Exception:
        return

    if ch == '1':
        print("Received '1' - starting function1...")
        function1()
    elif ch == '2':
        print("Received '2' - starting function2...")
        function2()
    elif ch == '3':
        print("Received '3' - starting function3...")
        function3()
    else:
        print(f"Unknown input '{ch}'. Enter 1, 2, or 3.")


