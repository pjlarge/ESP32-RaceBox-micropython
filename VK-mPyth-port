def get_compass_direction(deg):
    """Return cardinal/intercardinal string for a heading in degrees."""
    if deg >= 337.5 or deg < 22.5:   return "N"
    if deg < 67.5:                    return "NE"
    if deg < 112.5:                   return "E"
    if deg < 157.5:                   return "SE"
    if deg < 202.5:                   return "S"
    if deg < 247.5:                   return "SW"
    if deg < 292.5:                   return "W"
    if deg < 337.5:                   return "NW"
    return ""


def decode_battery_status(batt):
    """Print battery info, interpretation differs by device type."""
    global device_type
    if device_type == 0:
        is_charging   = bool(batt & 0x80)
        battery_level = batt & 0x7F
        print(f"RaceBox Mini/Mini S - Charging: {'Yes' if is_charging else 'No'}, "
              f"Battery: {battery_level}%")
    elif device_type == 1:
        input_voltage = batt / 10.0
        print(f"RaceBox Micro - Input Voltage: {input_voltage:.1f} V")
    else:
        print("Battery status: Unknown device type")


def calculate_checksum(data, packet_length):
    """Fletcher-8 checksum used by RaceBox/u-blox protocol."""
    ck_a = 0
    ck_b = 0
    for i in range(2, packet_length - 2):
        ck_a = (ck_a + data[i]) & 0xFF
        ck_b = (ck_b + ck_a)   & 0xFF
    return ck_a, ck_b


# ================================================================
#  Payload parsing
# ================================================================

def parse_payload(data: bytes):
    """
    Entry point called for every BLE notification.
    Validates the packet, identifies message type, dispatches to the
    appropriate parser.
    """
    global updated_data

    # ---- Frame-start check ----
    if len(data) < 8 or data[0] != 0xB5 or data[1] != 0x62:
        print("Invalid frame start - not a RaceBox packet (or other data).")
        return

    # ---- Extract header fields ----
    msg_class      = data[2]
    msg_id         = data[3]
    payload_length = struct.unpack_from('<H', data, 4)[0]

    # ---- Packet length sanity check ----
    packet_length = 6 + payload_length + 2   # 6 header bytes + payload + 2 checksum bytes
    if packet_length > 512:
        print(f"Packet too large ({packet_length} bytes), ignoring.")
        return
    if len(data) < packet_length:
        print(f"Received {len(data)} bytes but expected {packet_length}, ignoring.")
        return

    # ---- Checksum validation ----
    ck_a, ck_b = calculate_checksum(data, packet_length)
    if data[packet_length - 2] != ck_a or data[packet_length - 1] != ck_b:
        print("Checksum validation failed, discarding packet.")
        return

    # ---- Dispatch by message class / ID ----
    if msg_class == 0xFF and msg_id == 0x01:
        parse_racebox_data_message(data)
    elif msg_class == 0xFF and msg_id == 0x21:
        print("History Data Message received (parsing not implemented).")
    elif msg_class == 0xFF and msg_id == 0x22:
        print("Standalone Recording Status received (parsing not implemented).")
    elif msg_class == 0xFF and msg_id == 0x23:
        print("Recorded Data Download received (parsing not implemented).")
    elif msg_class == 0xFF and msg_id == 0x26:
        print("Standalone Recording State Change received (parsing not implemented).")
    else:
        print(f"Unknown message class=0x{msg_class:02X} id=0x{msg_id:02X}, ignoring.")


def parse_racebox_data_message(data: bytes):
    """
    Unpack all fields from an 80-byte RaceBox Data Message payload.
    Offsets are per the RaceBox datasheet (header at 0, payload at 6).
    """
    global iTOW, year, month, day, hour, minute, second
    global validity_flags, time_accuracy, nanoseconds
    global fix_status, fix_status_flags, datetime_flags, num_svs
    global longitude, latitude, wgs_altitude, msl_altitude
    global horizontal_accuracy, vertical_accuracy
    global speed_val, heading, speed_accuracy, heading_accuracy
    global pdop, lat_lon_flags, battery_status
    global g_force_x, g_force_y, g_force_z
    global rot_rate_x, rot_rate_y, rot_rate_z
    global heading_degrees, compass_direction, updated_data

    # struct.unpack_from(fmt, buffer, offset)
    # '<' = little-endian  I=uint32  H=uint16  B=uint8  i=int32  h=int16
    iTOW             = struct.unpack_from('<I', data, 6)[0]
    year             = struct.unpack_from('<H', data, 10)[0]
    month            = data[12]
    day              = data[13]
    hour             = data[14]
    minute           = data[15]
    second           = data[16]
    validity_flags   = data[17]
    time_accuracy    = struct.unpack_from('<I', data, 18)[0]
    nanoseconds      = struct.unpack_from('<I', data, 22)[0]
    fix_status       = data[26]
    fix_status_flags = data[27]
    datetime_flags   = data[28]
    num_svs          = data[29]
    longitude        = struct.unpack_from('<i', data, 30)[0]   # signed
    latitude         = struct.unpack_from('<i', data, 34)[0]   # signed
    wgs_altitude     = struct.unpack_from('<i', data, 38)[0]   # signed
    msl_altitude     = struct.unpack_from('<i', data, 42)[0]   # signed
    horizontal_accuracy = struct.unpack_from('<I', data, 46)[0]
    vertical_accuracy   = struct.unpack_from('<I', data, 50)[0]
    speed_val        = struct.unpack_from('<I', data, 54)[0]
    heading          = struct.unpack_from('<I', data, 58)[0]
    speed_accuracy   = struct.unpack_from('<I', data, 62)[0]
    heading_accuracy = struct.unpack_from('<I', data, 66)[0]
    pdop             = struct.unpack_from('<H', data, 70)[0]
    lat_lon_flags    = data[72]
    battery_status   = data[73]
    g_force_x        = struct.unpack_from('<h', data, 74)[0]   # signed int16
    g_force_y        = struct.unpack_from('<h', data, 76)[0]
    g_force_z        = struct.unpack_from('<h', data, 78)[0]

    # Note: rotRateX/Y/Z were in the original global list but not in the
    # datasheet offsets above (the 80-byte payload ends at offset 79).
    # Set to 0 until confirmed offset is available from datasheet.
    rot_rate_x = rot_rate_y = rot_rate_z = 0

    heading_degrees   = heading / 100000.0
    compass_direction = get_compass_direction(heading_degrees)
    updated_data      = True


