def print_data_to_oled():
    """Display key values on the 128x128 SPI colour OLED."""
    if not OLED_ENABLED:
        return
    oled.fill(0)

    fix_text   = {0: ("No Fix",  COLOR_RED),
                  2: ("2D Fix",  COLOR_CYAN),
                  3: ("3D Fix",  COLOR_GREEN)}.get(fix_status, ("??Fix", COLOR_MAGENTA))

    oled.draw_text(0, 0,  "RaceBox",    COLOR_RED)
    oled.draw_text(56, 0, "connected",  COLOR_GREEN)
    oled.draw_hline(0, 11, 128, COLOR_WHITE)

    y = 14
    oled.draw_text(0, y, "GPS: " + fix_text[0], fix_text[1]);  y += 9
    oled.draw_text(0, y, f"Lat: {latitude  / 1e7:.4f} deg", COLOR_WHITE);  y += 9
    oled.draw_text(0, y, f"Lon: {longitude / 1e7:.4f} deg", COLOR_WHITE);  y += 9

    if fix_status_flags & 0x20:
        oled.draw_text(0, y, f"Hdg:{heading_degrees:.1f} ({compass_direction})", COLOR_CYAN)
    else:
        oled.draw_text(0, y, "Heading: not valid", COLOR_RED)
    y += 9
    oled.draw_text(0, y, f"Spd:{speed_val * 3.6 / 1000.0:.1f} km/h", COLOR_WHITE);  y += 12
    oled.draw_text(0, y, f"Gx:{g_force_x / 1000.0:.2f} G", COLOR_BLUE);  y += 9
    oled.draw_text(0, y, f"Gy:{g_force_y / 1000.0:.2f} G", COLOR_BLUE);  y += 9
    oled.draw_text(0, y, f"Gz:{g_force_z / 1000.0:.2f} G", COLOR_BLUE);  y += 12
    oled.draw_text(0, y, f"Rx:{rot_rate_x / 100.0:.1f}d/s", COLOR_YELLOW);  y += 9
    oled.draw_text(0, y, f"Ry:{rot_rate_y / 100.0:.1f}d/s", COLOR_RED);     y += 9
    oled.draw_text(0, y, f"Rz:{rot_rate_z / 100.0:.1f}d/s", COLOR_GREEN)

    oled.show()


# ================================================================
#  BLE Central (client) implementation using MicroPython bluetooth
# ================================================================

class BLERaceBoxClient:
    """
    Pure-Python BLE central that scans for a RaceBox, connects,
    discovers the UART TX characteristic, and subscribes to notifications.

    MicroPython's bluetooth module uses an event/IRQ model rather than
    callbacks per-characteristic, so all BLE events come through
    _irq().
    """

    # GAP event codes
    _IRQ_SCAN_RESULT         = const(5)
    _IRQ_SCAN_DONE           = const(6)
    _IRQ_PERIPHERAL_CONNECT  = const(7)
    _IRQ_PERIPHERAL_DISCONNECT = const(8)
    _IRQ_GATTC_SERVICE_RESULT  = const(9)
    _IRQ_GATTC_SERVICE_DONE    = const(10)
    _IRQ_GATTC_CHARACTERISTIC_RESULT = const(11)
    _IRQ_GATTC_CHARACTERISTIC_DONE   = const(12)
    _IRQ_GATTC_NOTIFY        = const(18)

    # CCCD handle offset (standard BLE: descriptor is always +1 from char value handle for notify chars)
    _NOTIFY_ENABLE = b'\x01\x00'

    def __init__(self):
        self._ble     = bluetooth.BLE()
        self._ble.active(True)
        self._ble.irq(self._irq)

        self._conn_handle  = None
        self._tx_val_handle = None   # value handle for TX characteristic
        self._svc_start    = None
        self._svc_end      = None
        self._scanning     = False
        self._connecting   = False

    # ------------------------------------------------------------------
    def _irq(self, event, data):
        global do_connect, connected, racebox_addr, device_type

        # ---- Scan result ----
        if event == self._IRQ_SCAN_RESULT:
            addr_type, addr, adv_type, rssi, adv_data = data
            name = self._decode_name(adv_data)
            if name:
                print(f"BLE device found: {name}  addr={bytes(addr).hex(':')}")

            if name and name.startswith("RaceBox"):
                addr_str = bytes(addr).hex(':')

                # Determine device type
                if name.startswith("RaceBox Micro"):
                    device_type = 1
                elif name.startswith("RaceBox Mini"):
                    device_type = 0
                else:
                    device_type = -1

                # Address filter (optional)
                if TARGET_DEVICE_ADDRESS is not None:
                    if addr_str.lower() != TARGET_DEVICE_ADDRESS.lower():
                        print(f"  Address {addr_str} does not match TARGET_DEVICE_ADDRESS, skipping.")
                        return
                    else:
                        print(f"  Matched TARGET_DEVICE_ADDRESS {addr_str}.")

                print(f"RaceBox found: '{name}'  ({addr_str})  Connecting...")
                self._ble.gap_scan(None)   # stop scan
                self._scanning = False
                racebox_addr   = bytes(addr)
                self._ble.gap_connect(addr_type, addr)
                self._connecting = True

        # ---- Scan done ----
        elif event == self._IRQ_SCAN_DONE:
            if self._scanning:
                print("Scan finished without finding a RaceBox. Restarting scan...")
                self.start_scan()

        # ---- Connected ----
        elif event == self._IRQ_PERIPHERAL_CONNECT:
            conn_handle, addr_type, addr = data
            self._conn_handle = conn_handle
            self._connecting  = False
            connected         = True
            print(f"RaceBox Connected!  handle={conn_handle}")
            # Start service discovery
            self._ble.gattc_discover_services(conn_handle)

        # ---- Disconnected ----
        elif event == self._IRQ_PERIPHERAL_DISCONNECT:
            conn_handle, addr_type, addr = data
            self._conn_handle   = None
            self._tx_val_handle = None
            connected           = False
            print("Disconnected from RaceBox! Restarting scan...")
            if OLED_ENABLED:
                oled.fill(0)
                oled.draw_text(0, 40, "RaceBox DISCONNECTED", COLOR_RED)
                oled.show()
            self.start_scan()

        # ---- Service discovery result ----
        elif event == self._IRQ_GATTC_SERVICE_RESULT:
            conn_handle, start_handle, end_handle, uuid = data
            if bluetooth.UUID(bytes(uuid)) == UART_SERVICE_UUID:
                print("Found UART service.")
                self._svc_start = start_handle
                self._svc_end   = end_handle

        elif event == self._IRQ_GATTC_SERVICE_DONE:
            conn_handle, status = data
            if self._svc_start is not None:
                self._ble.gattc_discover_characteristics(
                    conn_handle, self._svc_start, self._svc_end)
            else:
                print("UART service not found, disconnecting.")
                self._ble.gap_disconnect(conn_handle)

        # ---- Characteristic discovery result ----
        elif event == self._IRQ_GATTC_CHARACTERISTIC_RESULT:
            conn_handle, def_handle, val_handle, properties, uuid = data
            if bluetooth.UUID(bytes(uuid)) == TX_CHAR_UUID:
                print(f"Found TX characteristic  val_handle={val_handle}")
                self._tx_val_handle = val_handle

        elif event == self._IRQ_GATTC_CHARACTERISTIC_DONE:
            conn_handle, status = data
            if self._tx_val_handle is not None:
                # Write 0x0001 to CCCD (val_handle + 1) to enable notifications
                cccd_handle = self._tx_val_handle + 1
                self._ble.gattc_write(conn_handle, cccd_handle,
                                      self._NOTIFY_ENABLE, 1)
                print("Subscribed to TX notifications.")
            else:
                print("TX characteristic not found.")

        # ---- Incoming notification ----
        elif event == self._IRQ_GATTC_NOTIFY:
            conn_handle, val_handle, notify_data = data
            if val_handle == self._tx_val_handle:
                payload = bytes(notify_data)
                if len(payload) < 80:
                    print(f"Short payload ({len(payload)} bytes) - "
                          "expected 80 for a RaceBox Data Message.")
                parse_payload(payload)

    # ------------------------------------------------------------------
    @staticmethod
    def _decode_name(adv_data: bytes) -> str:
        """Extract the Complete/Shortened Local Name from raw adv_data."""
        i = 0
        while i < len(adv_data):
            length = adv_data[i]
            if length == 0:
                break
            ad_type = adv_data[i + 1]
            if ad_type in (0x08, 0x09):   # Shortened / Complete Local Name
                try:
                    return adv_data[i + 2: i + 1 + length].decode('utf-8')
                except Exception:
                    pass
            i += 1 + length
        return ""

    # ------------------------------------------------------------------
    def start_scan(self):
        """Start an indefinite active BLE scan."""
        print("Starting BLE scan...")
        self._scanning = True
        # duration_ms=0 → scan until stopped; interval=45 ms, window=15 ms, active=True
        self._ble.gap_scan(0, 45000, 15000, True)


