def print_data_to_serial():
    """Rate-limited serial printout of the latest parsed RaceBox data."""
    global last_output_time_serial

    now = time.ticks_ms()
    if time.ticks_diff(now, last_output_time_serial) < OUTPUT_INTERVAL_MS:
        print("(skipping serial output - rate limited)")
        return
    last_output_time_serial = now

    fix_text = {0: "No Fix", 2: "2D Fix", 3: "3D Fix"}.get(fix_status, "Unknown")

    print()
    print("--- Updated values from RaceBox Data Message ---")
    print("-" * 66)
    print(f"iTOW:               {iTOW} ms")
    print(f"Date (UTC):         {year:04d}-{month:02d}-{day:02d}")
    print(f"Time (UTC):         {hour:02d}:{minute:02d}:{second:02d}")
    print(f"GPS Fix:            {fix_text}")
    print(f"Satellites:         {num_svs}")
    print(f"Latitude:           {latitude  / 1e7:.7f} deg")
    print(f"Longitude:          {longitude / 1e7:.7f} deg")
    print(f"WGS Altitude:       {wgs_altitude / 1000.0:.2f} m")
    print(f"MSL Altitude:       {msl_altitude / 1000.0:.2f} m")
    print(f"Horiz. Accuracy:    {horizontal_accuracy / 1000.0:.2f} m")
    print(f"Vert.  Accuracy:    {vertical_accuracy  / 1000.0:.2f} m")
    print(f"Speed:              {speed_val / 1000.0:.2f} m/s  "
          f"({speed_val * 3.6 / 1000.0:.2f} km/h)")
    print(f"Speed Accuracy:     {speed_accuracy / 1000.0:.2f} m/s")
    heading_valid = bool(fix_status_flags & 0x20)
    print(f"Heading:            {heading_degrees:.1f} deg  "
          f"({compass_direction})  "
          f"[{'valid' if heading_valid else 'NOT valid - may need movement'}]")
    print(f"Heading Accuracy:   {heading_accuracy / 1e5:.1f} deg")
    print(f"PDOP:               {pdop / 100.0:.2f}")
    print(f"G-Force X:          {g_force_x / 1000.0:.3f} G")
    print(f"G-Force Y:          {g_force_y / 1000.0:.3f} G")
    print(f"G-Force Z:          {g_force_z / 1000.0:.3f} G")
    print(f"Rot Rate X:         {rot_rate_x / 100.0:.2f} deg/s")
    print(f"Rot Rate Y:         {rot_rate_y / 100.0:.2f} deg/s")
    print(f"Rot Rate Z:         {rot_rate_z / 100.0:.2f} deg/s")
    print("Fix Status Flags:")
    print(f"  Bit 0  Valid Fix:                    {'Yes' if fix_status_flags & 0x01 else 'No'}")
    print(f"  Bit 1  Diff. Corrections Applied:    {'Yes' if fix_status_flags & 0x02 else 'No'}")
    print(f"  Bits 4-2  Power State:               {(fix_status_flags >> 2) & 0x07}")
    print(f"  Bit 5  Valid Heading:                {'Yes' if fix_status_flags & 0x20 else 'No'}")
    print(f"  Bits 7-6  Carrier Phase Solution:    {(fix_status_flags >> 6) & 0x03}")
    decode_battery_status(battery_status)
    print("-" * 66)
    print()


