def main():
    global updated_data

    print()
    print("  ############################################################")
    print("  ###       ESP32 MicroPython BLE RaceBox Client           ###")
    print("  ############################################################")
    print()
    if TARGET_DEVICE_ADDRESS:
        print(f"  Will only connect to RaceBox at address: {TARGET_DEVICE_ADDRESS}")
    else:
        print("  Will connect to any RaceBox found (no TARGET_DEVICE_ADDRESS set).")
    print()
    print("  Type 1 / 2 / 3 in the REPL to call stub functions.")
    print()

    client = BLERaceBoxClient()
    client.start_scan()

    # ---- Main loop ----
    while True:
        interpret_serial_input()

        if updated_data:
            print_data_to_serial()
            print_data_to_oled()
            updated_data = False

        time.sleep_ms(20)   # yield; BLE IRQs fire in background


if __name__ == "__main__":
    main()
